<Application
    x:Class="VoltStream.WPF.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:VoltStream.WPF">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/VoltStream.WPF;component/Commons/Styles/Theme/Tokens.xaml" />
                <ResourceDictionary Source="pack://application:,,,/VoltStream.WPF;component/Commons/Styles/Theme/Light.xaml" />

                <ResourceDictionary Source="pack://application:,,,/VoltStream.WPF;component/Commons/Converters/Converters.xaml" />

                <ResourceDictionary Source="pack://application:,,,/VoltStream.WPF;component/Commons/Styles/ButtonStyles.xaml" />
                <ResourceDictionary Source="pack://application:,,,/VoltStream.WPF;component/Commons/Styles/FloatingLable.xaml" />
                <ResourceDictionary Source="/Commons/Styles/ScrollBarStyles.xaml" />
                <ResourceDictionary Source="/Commons/Styles/ModernControls.xaml" />
                <ResourceDictionary Source="/Commons/Styles/BaseStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>

    </Application.Resources>

</Application>
