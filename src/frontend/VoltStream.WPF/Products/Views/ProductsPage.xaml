<Page
    x:Class="VoltStream.WPF.Products.Views.ProductsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:VoltStream.WPF.Commons.Utils"
    xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
    Title="ProductsPage"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Border
            Margin="0,0,0,12"
            Padding="18,16"
            Background="White"
            BorderBrush="#E6E8EF"
            BorderThickness="1"
            CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Filtrlar (bitta qator)  -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!--  Mahsulot turi  -->
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Margin="2,0,0,4" FontSize="12" Foreground="#8A94A6" Text="Mahsulot turi" />
                        <ComboBox
                            x:Name="cbxCategory"
                            Width="240"
                            DisplayMemberPath="Name"
                            IsEditable="True"
                            ItemsSource="{Binding Categories}"
                            SelectedItem="{Binding SelectedCategory}"
                            Style="{StaticResource ModernCombo}" />
                    </StackPanel>

                    <!--  Nomi  -->
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Margin="2,0,0,4" FontSize="12" Foreground="#8A94A6" Text="Nomi" />
                        <ComboBox
                            x:Name="cbxProductName"
                            Width="240"
                            DisplayMemberPath="Name"
                            IsEditable="True"
                            ItemsSource="{Binding Products}"
                            SelectedItem="{Binding SelectedProduct}"
                            Style="{StaticResource ModernCombo}" />
                    </StackPanel>

                    <!--  Hammasini ko'rsatish (0 qoldiqlar bilan)  -->
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Margin="2,0,0,4" FontSize="12" Foreground="#8A94A6" Text=" " />
                        <Border Height="38">
                            <CheckBox
                                VerticalAlignment="Center"
                                Content="Hammasini ko‘rsatish"
                                IsChecked="{Binding ShowAllBalances, Mode=TwoWay}"
                                Style="{StaticResource ModernCheck}" />
                        </Border>
                    </StackPanel>

                    <!--  Tozalash  -->
                    <Button
                        VerticalAlignment="Bottom"
                        Background="White"
                        BorderBrush="#D0D5DD"
                        BorderThickness="1.5"
                        Command="{Binding ClearFilterCommand}"
                        Foreground="#0A003A"
                        Style="{StaticResource ToolButton}"
                        ToolTip="Tozalash">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage VerticalAlignment="Center" Width="14" Height="14" Foreground="#475467" Icon="Broom" />
                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Tozalash" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!--  Amallar (ikonali) - ma'lumot bo'lmasa o'chiriladi  -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button
                        Width="44"
                        Margin="0,0,8,0"
                        Padding="0"
                        Background="#6C5CE7"
                        Command="{Binding PreviewCommand}"
                        IsEnabled="{Binding FilteredProductItems.Count, Converter={StaticResource CountToBool}}"
                        Style="{StaticResource ToolButton}"
                        ToolTip="Ko‘rish">
                        <fa:IconImage Width="16" Height="16" Foreground="White" Icon="Eye" />
                    </Button>
                    <Button
                        Width="44"
                        Margin="0,0,8,0"
                        Padding="0"
                        Background="#EC407A"
                        Command="{Binding PrintCommand}"
                        IsEnabled="{Binding FilteredProductItems.Count, Converter={StaticResource CountToBool}}"
                        Style="{StaticResource ToolButton}"
                        ToolTip="Pechat">
                        <fa:IconImage Width="16" Height="16" Foreground="White" Icon="Print" />
                    </Button>
                    <Button
                        Width="44"
                        Padding="0"
                        Background="#1D8A4E"
                        Command="{Binding ExportToExcelCommand}"
                        IsEnabled="{Binding FilteredProductItems.Count, Converter={StaticResource CountToBool}}"
                        Style="{StaticResource ToolButton}"
                        ToolTip="Excel">
                        <fa:IconImage Width="16" Height="16" Foreground="White" Icon="FileExcel" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid
            Grid.Row="1"
            AlternatingRowBackground="#F5F5F5"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            FontSize="14"
            HeadersVisibility="Column, Row"
            IsReadOnly="True"
            ItemsSource="{Binding FilteredProductItems}"
            SelectionMode="Single"
            utils:DataGridRowNumbering.IsEnabled="True">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Category}"
                    Header="Mahsulot turi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5,0" />
                            <Setter Property="TextAlignment" Value="Left" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="2*"
                    Binding="{Binding Name}"
                    Header="Nomi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5,0" />
                            <Setter Property="TextAlignment" Value="Left" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding RollLength, StringFormat={}{0:N0}}"
                    Header="To'plamda">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5,0" />
                            <Setter Property="TextAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="utils:NumericInput.IsNumeric" Value="True" />
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Quantity, StringFormat={}{0:N0}}"
                    Header="To'plam soni">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5,0" />
                            <Setter Property="TextAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="utils:NumericInput.IsNumeric" Value="True" />
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding TotalCount, StringFormat={}{0:N0}}"
                    Header="Jami">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5,0" />
                            <Setter Property="TextAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="utils:NumericInput.IsNumeric" Value="True" />
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Unit}"
                    Header="O‘lchov birligi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5,0" />
                            <Setter Property="TextAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Price, StringFormat={}{0:N2}}"
                    Header="Narxi">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5,0" />
                            <Setter Property="TextAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="utils:NumericInput.IsNumeric" Value="True" />
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="1.5*"
                    Binding="{Binding TotalAmount, StringFormat={}{0:N2}}"
                    Header="Umumiy summa">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5,0" />
                            <Setter Property="TextAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="utils:NumericInput.IsNumeric" Value="True" />
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>

