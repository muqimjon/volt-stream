<Page x:Class="VoltStream.WPF.Supplies.Views.SuppliesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:VoltStream.WPF.Supplies.Views"
      xmlns:controls="clr-namespace:VoltStream.WPF.Commons.UserControls"
      xmlns:utils="clr-namespace:VoltStream.WPF.Commons.Utils"
      xmlns:conv="clr-namespace:VoltStream.WPF.Commons.Converters"
      mc:Ignorable="d"
      d:DesignHeight="450"
      d:DesignWidth="800"
      Title="SupplyPage">

	<Grid Margin="10" Background="{DynamicResource Canvas}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="12,4" Margin="0,0,0,6">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"
                                  MaxWidth="600" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid  Grid.Row="0"
                       Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Sana:"
                               VerticalAlignment="Center"
                               FontSize="14" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="0" Grid.Column="1">

					<Grid.ColumnDefinitions>
						<ColumnDefinition/>
						<ColumnDefinition/>
					</Grid.ColumnDefinitions>

					<controls:UserCalendar x:Name="date" Margin="0,4"
                                           SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left"
                                           Width="150"
                                           FontSize="14"/>
				</Grid>
                

				<Grid Grid.Row="1"
                      Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Maxsulot:"
                               VerticalAlignment="Center"
                               FontSize="14" />
                    </StackPanel>
                </Grid>
                <Grid Grid.Row="1"
                      Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="75*" />
                        <ColumnDefinition Width="109*" />
                        <ColumnDefinition Width="184*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Turi"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextTertiary}"
                               Margin="10,0,10,0"
                               IsHitTestVisible="False"
                               Panel.ZIndex="1"
                               Visibility="{Binding ElementName=cbxCategory, Path=Text.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Grid.ColumnSpan="2" />

                    <ComboBox x:Name="cbxCategory" Style="{StaticResource RoundedCombo}" Height="28"
                              IsEditable="True"
                              StaysOpenOnEdit="True"
                              Margin="0,4,10,4"
                              ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              Text="{Binding CategoryText, UpdateSourceTrigger=LostFocus}"
                              DisplayMemberPath="Name"
                              VerticalAlignment="Center"
                              FontSize="14"
                              Grid.ColumnSpan="2" />

                    <TextBlock Grid.Column="2"
                               Text="Nomi"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextTertiary}"
                               Margin="10,0,10,0"
                               IsHitTestVisible="False"
                               Panel.ZIndex="1"
                               Visibility="{Binding ElementName=cbxProduct,Path=Text.IsEmpty,Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <ComboBox x:Name="cbxProduct" Style="{StaticResource RoundedCombo}" Height="28" Margin="0,4"
                              Grid.Column="2"
                              IsEditable="True"
                              ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct}"
                              Text="{Binding ProductText, UpdateSourceTrigger=LostFocus}"
                              DisplayMemberPath="Name"
                              VerticalAlignment="Center"
                              FontSize="14"/>
                </Grid>
                <Grid Grid.Row="2"
                      Grid.Column="0">
                    <Label Content="To'plamda:"
                           VerticalAlignment="Center"
                           FontSize="14" />
                </Grid>
                <Grid Grid.Row="2"
                      Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="85" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

					<ComboBox x:Name="cbxWarehouseStock" Style="{StaticResource RoundedCombo}" Height="28"
                              IsEditable="True"
                              ItemsSource="{Binding WarehouseStocks}"
                              SelectedItem="{Binding SelectedWarehouseStock}"
                              utils:NumericInput.Value="{Binding WarehouseStockValue, UpdateSourceTrigger=LostFocus}"
                              utils:NumericInput.IsNumeric="True"
                              utils:NumericInput.Precision="2"
                              DisplayMemberPath="LengthPerRoll"
                              Margin="0,4,10,4"
                              HorizontalAlignment="Stretch"
                              HorizontalContentAlignment="Right"
                              VerticalAlignment="Center"
                              FontSize="14"/>

                    <TextBlock Grid.Column="1"
                               Text="To'plam soni:"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               FontSize="14"
                               Margin="0,0,5,0" />
                    <TextBox Grid.Column="2"
                             x:Name="tbxRollCount" Style="{StaticResource RoundedTextBox}" Height="28" Margin="0,4"
                             utils:NumericInput.Value="{Binding RollCount, UpdateSourceTrigger=PropertyChanged}"
                             utils:NumericInput.Precision="0"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Stretch"
                             Validation.ErrorTemplate="{x:Null}"    
                             HorizontalContentAlignment="Right"
                             FontSize="14"
                             utils:NumericInput.IsNumeric="True"
                              />
                </Grid>
                <Grid Grid.Row="3"
                      Grid.Column="0">
                    <Label Content="Jami:"
                           VerticalAlignment="Center"
                           FontSize="14" />
                </Grid>
                <Grid Grid.Row="3"
                      Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="85" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             x:Name="totalMeters" Style="{StaticResource RoundedTextBox}" Height="28"
                             utils:NumericInput.Value="{Binding TotalQuantity, Mode=OneWay}"
                             utils:NumericInput.Precision="2"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Stretch"
                             HorizontalContentAlignment="Right"
                             FontSize="14"
                             Margin="0,4,10,4"
                             Validation.ErrorTemplate="{x:Null}"
                             utils:NumericInput.IsNumeric="True"
                             IsTabStop="False"
                             IsReadOnly="True" />
                    <Label Grid.Column="1"
                           Content="O'lcho'vi:"
                           VerticalAlignment="Center"
                           Margin="10,0"
                           FontSize="14" />
                    <ComboBox Grid.Column="2"
                              x:Name="cbxUnit" Style="{StaticResource RoundedCombo}" Height="28" Margin="0,4"
                              Text="{Binding Unit, UpdateSourceTrigger=PropertyChanged}"
                              StaysOpenOnEdit="True"
                          VerticalAlignment="Center"
                          FontSize="14"
                          >
                        <ComboBoxItem >metr</ComboBoxItem>
                        <ComboBoxItem >dona</ComboBoxItem>
                    </ComboBox>

                </Grid>
                <Grid Grid.Row="4"
                      Grid.Column="0">
                    <Label Content="Narxi:"
                           VerticalAlignment="Center"
                           FontSize="14" />
                </Grid>

                <Grid Grid.Row="4"
                      Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="85" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" 
                             x:Name="txtUnitPrice" Style="{StaticResource RoundedTextBox}" Height="28"
                             utils:NumericInput.Value="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}"
                             utils:NumericInput.IsNumeric="True"
                             utils:NumericInput.Precision="2"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Stretch"
                             HorizontalContentAlignment="Right"
                             FontSize="14"
                             Validation.ErrorTemplate="{x:Null}"
                             Margin="0,4,10,4"       
                              />
                    <Label Grid.Column="1"
                           Content="Chegirma: %"
                           VerticalAlignment="Center"
                           FontSize="14"
                           Margin="-10,0,0,0" />
                    <TextBox Grid.Column="2"
                             x:Name="tbxDiscountRate" Style="{StaticResource RoundedTextBox}" Height="28" Margin="0,4"
                             utils:NumericInput.Value="{Binding DiscountRate, UpdateSourceTrigger=PropertyChanged}"
                             utils:NumericInput.Precision="2"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Stretch"
                             HorizontalContentAlignment="Right"
                             FontSize="14"
                             Validation.ErrorTemplate="{x:Null}"
                             utils:NumericInput.IsNumeric="True"
                             />
                </Grid>
                <Grid Grid.Row="5" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0"
                            x:Name="addSupplyBtn"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding SaveCommand}"
                            VerticalAlignment="Center"
                            FontSize="14">
                        <TextBlock Foreground="White"
                                   Text="{Binding IsEditing, Converter={StaticResource BoolToTextConverter}, ConverterParameter=' Saqlash | Qoshish '}" />
                    </Button>

                    <Button Grid.Column="1"
                            x:Name="cancelBtn"
                            Style="{StaticResource SecondaryButton}"
                            Content="Bekor qilish"
                            Command="{Binding CancelEditCommand}"
                            Visibility="{Binding IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}"
                            VerticalAlignment="Center"
                            Margin="5,4,0,4"
                            FontSize="14" />
                </Grid>
            </Grid>
            <Grid Grid.Column="2">
                <Border Style="{StaticResource CardBorder}">
                    <Label Content="Mahsulot haqida ma'lumotlar.."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16"
                           FontWeight="Thin"
                           Foreground="{DynamicResource TextTertiary}"/>
                </Border>
            </Grid>
        </Grid>
        </Border>
        <DataGrid Grid.Row="1"
                  x:Name="supplyDataGrid"
                  ItemsSource="{Binding PagedSupplies}"
                  SelectedItem="{Binding SelectedSupply}"
                  HorizontalAlignment="Center"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column, Row"
                  utils:DataGridRowNumbering.IsEnabled="True"
                  Margin="0 10 0 0">
            <DataGrid.InputBindings>
                <MouseBinding Gesture="LeftDoubleClick" Command="{Binding EditItemCommand}" CommandParameter="{Binding SelectedSupply}" />
                <KeyBinding Key="Delete" Command="{Binding DeleteItemCommand}" CommandParameter="{Binding SelectedSupply}" />
            </DataGrid.InputBindings>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Sana"
                                    Width="*"
                                    ElementStyle="{StaticResource CenterCellText}"
                                    Binding="{Binding Date, Converter={StaticResource UtcToUzbekistanTimeConverter},StringFormat=dd.MM.yyyy}" />
                <DataGridTextColumn Header="Mahsulot turi"
                                    Binding="{Binding CategoryName}"
                                    Width="1.5*" />
                <DataGridTextColumn Header="Mahsulot"
                                    Binding="{Binding ProductName}"
                                    Width="2*" />
                <DataGridTextColumn Header="To'plam soni"
                                    Binding="{Binding RollCount, StringFormat=N2}"
                                    ElementStyle="{StaticResource RightCellText}"
                                    Width="*" />
                <DataGridTextColumn Header="To'plamda"
                                    Binding="{Binding LengthPerRoll, StringFormat=N2}"
                                    ElementStyle="{StaticResource RightCellText}"
                                    Width="*" />
                <DataGridTextColumn Header="Jami"
                                    Binding="{Binding TotalLength, StringFormat=N2}"
                                    ElementStyle="{StaticResource RightCellText}"
                                    Width="*" />
            </DataGrid.Columns>
        </DataGrid>
        <controls:Pager Grid.Row="2" Margin="0,12,0,0" DataContext="{Binding Pagination}" />
        <controls:BusyOverlay Grid.Row="0" Grid.RowSpan="3"
                              IsBusy="{Binding IsLoading}"
                              Message="Yuklanmoqda..." />
    </Grid>
</Page>
