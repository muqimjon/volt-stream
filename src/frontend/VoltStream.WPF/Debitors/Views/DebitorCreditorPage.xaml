<Page
    x:Class="VoltStream.WPF.Debitors.Views.DebitorCreditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:VoltStream.WPF.Commons.Utils"
    xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
    Title="Haqdorlik va qarzdorlik oynasi"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Page.Resources>
        <!--  Zamonaviy TextBox  -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#2D3436" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D0D5DD" />
            <Setter Property="CaretBrush" Value="#0A003A" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1.5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#B0B6C0" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#6C5CE7" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#F2F4F7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Dropdown elementi  -->
        <Style x:Key="ModernComboItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#2D3436" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ib" Margin="4,1" Padding="10,8" CornerRadius="6" Background="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ib" Property="Background" Value="#F1EEFE" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ib" Property="Background" Value="#6C5CE7" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Zamonaviy ComboBox (editable'ni ham qo'llab-quvvatlaydi)  -->
        <Style x:Key="ModernCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#2D3436" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#D0D5DD" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource ModernComboItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="bd" CornerRadius="8" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1.5" />
                            <ToggleButton x:Name="toggle" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <Path HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Margin="0,0,12,0" Data="M0,0 L8,0 L4,5 Z" Fill="#667085" />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="contentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="12,0,34,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <TextBox x:Name="PART_EditableTextBox" Visibility="Hidden"
                                     Margin="9,0,34,0" VerticalAlignment="Center" VerticalContentAlignment="Center"
                                     Background="Transparent" BorderThickness="0" Foreground="#2D3436"
                                     CaretBrush="#0A003A" Focusable="True"
                                     IsReadOnly="{TemplateBinding IsReadOnly}" />
                            <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" Focusable="False" PopupAnimation="Slide">
                                <Border Margin="0,4,0,6" CornerRadius="8" Background="White"
                                        BorderBrush="#E6E8EF" BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.18" Color="#555555" />
                                    </Border.Effect>
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                                <Setter TargetName="contentSite" Property="Visibility" Value="Hidden" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#B0B6C0" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#6C5CE7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Zamonaviy CheckBox  -->
        <Style x:Key="ModernCheck" TargetType="CheckBox">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#2D3436" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="box" Width="20" Height="20" CornerRadius="5"
                                    BorderBrush="#C0C6D0" BorderThickness="1.5" Background="White"
                                    VerticalAlignment="Center">
                                <Path x:Name="check" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Data="M3,8 L7,12 L13,4" Stroke="White" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="box" Property="BorderBrush" Value="#6C5CE7" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="box" Property="Background" Value="#6C5CE7" />
                                <Setter TargetName="box" Property="BorderBrush" Value="#6C5CE7" />
                                <Setter TargetName="check" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--  Zamonaviy tugma (rangni Background orqali o'zgartirish mumkin)  -->
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#0A003A" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.90" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.80" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Margin="0,0,0,12"
            Padding="18,16"
            Background="White"
            BorderBrush="#E6E8EF"
            BorderThickness="1"
            CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Filtrlar (bitta qator)  -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!--  Summa  -->
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Margin="2,0,0,4" FontSize="12" Foreground="#8A94A6" Text="Summa" />
                        <TextBox
                            Width="150"
                            Style="{StaticResource ModernTextBox}"
                            Text="{Binding Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!--  Belgi  -->
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Margin="2,0,0,4" FontSize="12" Foreground="#8A94A6" Text="Belgi" />
                        <ComboBox
                            x:Name="cbxSign"
                            Width="84"
                            ItemsSource="{Binding Signs}"
                            SelectedItem="{Binding Sign}"
                            Style="{StaticResource ModernCombo}" />
                    </StackPanel>

                    <!--  Barcha qoldiq  -->
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Margin="2,0,0,4" FontSize="12" Foreground="#8A94A6" Text=" " />
                        <Border Height="38">
                            <CheckBox Content="Barcha qoldiq" VerticalAlignment="Center" Style="{StaticResource ModernCheck}" />
                        </Border>
                    </StackPanel>

                    <!--  Mijoz  -->
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Margin="2,0,0,4" FontSize="12" Foreground="#8A94A6" Text="Mijozni tanlang" />
                        <ComboBox
                            x:Name="cbxCustomer"
                            Width="240"
                            DisplayMemberPath="Name"
                            IsEditable="True"
                            ItemsSource="{Binding AvailableCustomers}"
                            SelectedItem="{Binding SelectedCustomer}"
                            Style="{StaticResource ModernCombo}" />
                    </StackPanel>

                    <!--  Tozalash  -->
                    <Button
                        VerticalAlignment="Bottom"
                        Background="White"
                        BorderBrush="#D0D5DD"
                        BorderThickness="1.5"
                        Command="{Binding ClearFilterCommand}"
                        Foreground="#0A003A"
                        Style="{StaticResource ToolButton}"
                        ToolTip="Tozalash">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage VerticalAlignment="Center" Width="14" Height="14" Foreground="#475467" Icon="Broom" />
                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Tozalash" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!--  Amallar (ikonali) - ma'lumot bo'lmasa o'chiriladi  -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button
                        Width="44"
                        Margin="0,0,8,0"
                        Padding="0"
                        Background="#6C5CE7"
                        Command="{Binding PreviewCommand}"
                        IsEnabled="{Binding FilteredDebitorCreditorItems.Count, Converter={StaticResource CountToBool}}"
                        Style="{StaticResource ToolButton}"
                        ToolTip="Ko‘rish">
                        <fa:IconImage Width="16" Height="16" Foreground="White" Icon="Eye" />
                    </Button>
                    <Button
                        Width="44"
                        Margin="0,0,8,0"
                        Padding="0"
                        Background="#EC407A"
                        Command="{Binding PrintCommand}"
                        IsEnabled="{Binding FilteredDebitorCreditorItems.Count, Converter={StaticResource CountToBool}}"
                        Style="{StaticResource ToolButton}"
                        ToolTip="Pechat">
                        <fa:IconImage Width="16" Height="16" Foreground="White" Icon="Print" />
                    </Button>
                    <Button
                        Width="44"
                        Padding="0"
                        Background="#1D8A4E"
                        Command="{Binding ExportToExcelCommand}"
                        IsEnabled="{Binding FilteredDebitorCreditorItems.Count, Converter={StaticResource CountToBool}}"
                        Style="{StaticResource ToolButton}"
                        ToolTip="Excel">
                        <fa:IconImage Width="16" Height="16" Foreground="White" Icon="FileExcel" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid
            Grid.Row="1"
            AlternatingRowBackground="#F5F5F5"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            FontSize="14"
            HeadersVisibility="Column, Row"
            IsReadOnly="True"
            ItemsSource="{Binding FilteredDebitorCreditorItems}"
            SelectionMode="Single"
            utils:DataGridRowNumbering.IsEnabled="True">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="2*"
                    Binding="{Binding Customer}"
                    Header="Mijoz">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5,0" />
                            <Setter Property="TextAlignment" Value="Left" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Phone}"
                    Header="Telefon">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5,0" />
                            <Setter Property="TextAlignment" Value="Left" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="2*"
                    Binding="{Binding Address}"
                    Header="Manzil">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5,0" />
                            <Setter Property="TextAlignment" Value="Left" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Discount, StringFormat={}{0:N2}}"
                    Header="Bonus">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5,0" />
                            <Setter Property="TextAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="utils:NumericInput.IsNumeric" Value="True" />
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Debitor, StringFormat={}{0:N2}}"
                    Header="Debitor">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5,0" />
                            <Setter Property="TextAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="utils:NumericInput.IsNumeric" Value="True" />
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Creditor, StringFormat={}{0:N2}}"
                    Header="Kreditor">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5,0" />
                            <Setter Property="TextAlignment" Value="Right" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.EditingElementStyle>
                        <Style TargetType="TextBox">
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="utils:NumericInput.IsNumeric" Value="True" />
                        </Style>
                    </DataGridTextColumn.EditingElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Padding="5"
                Background="#F9F9F9"
                BorderBrush="#DDD"
                BorderThickness="1,1,0,1">
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,10,0"
                        FontSize="14"
                        FontWeight="Bold"
                        Text="Jami bonus:" />
                    <TextBlock
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="#8B8000"
                        Text="{Binding FinalDiscount, StringFormat=N2}" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="1"
                Padding="5"
                Background="#F9F9F9"
                BorderBrush="#DDD"
                BorderThickness="1,1,0,1">
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,10,0"
                        FontSize="14"
                        FontWeight="Bold"
                        Text="Jami debitor:" />
                    <TextBlock
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="#006400"
                        Text="{Binding FinalDebitor, StringFormat=N2}" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="2"
                Padding="5"
                Background="#F9F9F9"
                BorderBrush="#DDD"
                BorderThickness="1,1,0,1">
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,10,0"
                        FontSize="14"
                        FontWeight="Bold"
                        Text="Jami kreditor:" />
                    <TextBlock
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="#DC143C"
                        Text="{Binding FinalKreditor, StringFormat=N2}" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="3"
                Padding="5"
                Background="#E6F3FF"
                BorderBrush="#007ACC"
                BorderThickness="1">
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,10,0"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="#007ACC"
                        Text="Umumiy:" />
                    <TextBlock
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="{Binding FinalAmount, Converter={StaticResource BalanceToColorConverter}}"
                        Text="{Binding FinalAmount, StringFormat=N2}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>

