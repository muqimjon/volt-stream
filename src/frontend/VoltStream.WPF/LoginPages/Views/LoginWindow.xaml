<Window x:Class="VoltStream.WPF.LoginPages.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        xmlns:loc="clr-namespace:VoltStream.WPF.Commons.Localization"
        xmlns:utils="clr-namespace:VoltStream.WPF.Commons.Utils"
        mc:Ignorable="d"
        Title="VoltStream"
        Height="560"
        Width="900"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="LoginPasswordBox" TargetType="PasswordBox">
            <Setter Property="Height" Value="{DynamicResource ControlHeight}" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}" />
            <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1.5"
                                CornerRadius="{DynamicResource RadiusMd}">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Focus}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="14" Background="{DynamicResource Canvas}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <!--  Brand panel  -->
            <Border CornerRadius="14,0,0,14">
                <Border.Background>
                    <ImageBrush ImageSource="/Commons/Source/Images/oramkabel.png" Stretch="UniformToFill" />
                </Border.Background>
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{DynamicResource BrandPressedColor}" Offset="0" />
                            <GradientStop Color="{DynamicResource BrandColor}" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.OpacityMask>
                        <SolidColorBrush Color="Black" Opacity="0.82" />
                    </Border.OpacityMask>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Width="110" Height="110" Source="/Commons/Source/Images/LogoVolt.png" />
                        <TextBlock Margin="0,12,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Text="VoltStream" />
                        <TextBlock Width="280"
                                   Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="#E6E9F0"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Text="{loc:Loc Login.Tagline}" />
                    </StackPanel>
                </Border>
            </Border>

            <!--  Form panel  -->
            <Border Grid.Column="1" Background="{DynamicResource Surface}" CornerRadius="0,14,14,0">
                <Grid Margin="40,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" HorizontalAlignment="Right" Orientation="Horizontal">
                        <Button x:Name="btnMinimize" Click="BtnMinimize_Click" Style="{StaticResource IconButton}" Width="30" Height="28" ToolTip="{loc:Loc Login.Minimize}">
                            <Path Data="M 0,8 H 10" Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5" />
                        </Button>
                        <Button x:Name="btnClose" Click="BtnClose_Click" Style="{StaticResource IconButton}" Width="30" Height="28" Margin="6,0,0,0" ToolTip="{loc:Loc Common.Close}">
                            <Path Data="M 0,0 L 10,10 M 0,10 L 10,0" Stroke="{DynamicResource TextSecondary}" StrokeThickness="1.5" />
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock FontSize="{DynamicResource FontSizeDisplay}" FontWeight="Bold" Text="{loc:Loc Login.Welcome}" />
                        <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource TextSecondary}" Text="{loc:Loc Login.Subtitle}" />

                        <TextBlock Margin="0,28,0,6" Style="{StaticResource FieldLabel}" Text="{loc:Loc Login.Username}" />
                        <Grid>
                            <TextBox x:Name="txtUser"
                                     Style="{StaticResource ModernTextBox}"
                                     Padding="38,0,10,0"
                                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     utils:EnterKeyTab.IsEnabled="True" />
                            <fa:IconImage Width="15" Height="15" Margin="12,0,0,0"
                                          HorizontalAlignment="Left" VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextTertiary}" Icon="User" IsHitTestVisible="False" />
                        </Grid>

                        <TextBlock Margin="0,16,0,6" Style="{StaticResource FieldLabel}" Text="{loc:Loc Login.Password}" />
                        <Grid>
                            <PasswordBox x:Name="tbxPassword"
                                         Style="{StaticResource LoginPasswordBox}"
                                         Padding="38,0,10,0"
                                         PasswordChanged="TbxPassword_PasswordChanged"
                                         PreviewKeyDown="TbxPassword_PreviewKeyDown"
                                         utils:EnterKeyTab.IsEnabled="True" />
                            <fa:IconImage Width="15" Height="15" Margin="12,0,0,0"
                                          HorizontalAlignment="Left" VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextTertiary}" Icon="Lock" IsHitTestVisible="False" />
                        </Grid>

                        <CheckBox Margin="0,14,0,0"
                                  Content="{loc:Loc Login.RememberMe}"
                                  IsChecked="{Binding RememberMe}"
                                  Style="{StaticResource ModernCheck}" />

                        <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource Danger}" TextWrapping="Wrap"
                                   Text="{Binding Error}"
                                   Visibility="{Binding Error, Converter={StaticResource StringToVisibilityConverter}}" />
                        <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource Success}" TextWrapping="Wrap"
                                   Text="{Binding Success}"
                                   Visibility="{Binding Success, Converter={StaticResource StringToVisibilityConverter}}" />
                        <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource Warning}" TextWrapping="Wrap"
                                   Text="{Binding Warning}"
                                   Visibility="{Binding Warning, Converter={StaticResource StringToVisibilityConverter}}" />

                        <Button x:Name="btnLogin"
                                Margin="0,24,0,0"
                                Command="{Binding LoginCommand}"
                                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolToBoolConverter}}"
                                Style="{StaticResource PrimaryButton}">
                            <TextBlock Text="{loc:Loc Login.SignIn}" Foreground="White" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
