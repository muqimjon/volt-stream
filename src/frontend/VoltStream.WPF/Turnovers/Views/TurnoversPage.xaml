<Page
    x:Class="VoltStream.WPF.Turnovers.Views.TurnoversPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:VoltStream.WPF.Commons.UserControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:VoltStream.WPF.Commons.Utils"
    Title="TurnoversPage"
    d:DesignHeight="450"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Border
            Margin="0,0,0,12"
            Padding="18,14"
            Background="White"
            BorderBrush="#E6E8EF"
            BorderThickness="1"
            CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  Sanalar + mijoz + tozalash  -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock
                            Margin="2,0,0,4"
                            FontSize="12"
                            Foreground="#8A94A6"
                            Text="Boshlanish" />
                        <controls:UserCalendar
                            Width="130"
                            utils:EnterKeyTab.IsEnabled="True"
                            SelectedDate="{Binding BeginDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <StackPanel Margin="0,0,14,0">
                        <TextBlock
                            Margin="2,0,0,4"
                            FontSize="12"
                            Foreground="#8A94A6"
                            Text="Tugash" />
                        <controls:UserCalendar
                            Width="130"
                            utils:EnterKeyTab.IsEnabled="True"
                            SelectedDate="{Binding EndDate, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                    </StackPanel>

                    <StackPanel Margin="0,0,14,0">
                        <TextBlock
                            Margin="2,0,0,4"
                            FontSize="12"
                            Foreground="#8A94A6"
                            Text="Mijozni tanlang" />
                        <ComboBox
                            x:Name="cbxCustomer"
                            Width="240"
                            DisplayMemberPath="Name"
                            IsEditable="True"
                            ItemsSource="{Binding Customers}"
                            SelectedItem="{Binding SelectedCustomer}"
                            Style="{StaticResource ModernCombo}" />
                    </StackPanel>

                    <Button
                        VerticalAlignment="Bottom"
                        Background="White"
                        BorderBrush="#D0D5DD"
                        BorderThickness="1.5"
                        Command="{Binding ClearFilterCommand}"
                        Foreground="#0A003A"
                        Style="{StaticResource ToolButton}"
                        ToolTip="Tozalash">
                        <StackPanel Orientation="Horizontal">
                            <fa:IconImage
                                Width="14"
                                Height="14"
                                VerticalAlignment="Center"
                                Foreground="#475467"
                                Icon="Broom" />
                            <TextBlock
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Text="Tozalash" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!--  Qoldiqlar  -->
                <Border
                    Grid.Column="1"
                    Margin="0,0,16,0"
                    Padding="14,8"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="#F8F9FC"
                    CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="#667085"
                            Text="Boshlang'ich qoldiq:" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="12,0,0,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="#0A003A"
                            Text="{Binding BeginBalance, StringFormat={}{0:N2}}" />
                        <TextBlock
                            Grid.Row="1"
                            Margin="0,6,0,0"
                            VerticalAlignment="Center"
                            FontSize="13"
                            Foreground="#667085"
                            Text="Oxirgi qoldiq:" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="12,6,0,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="#0A003A"
                            Text="{Binding LastBalance, StringFormat={}{0:N2}}" />
                    </Grid>
                </Border>

                <!--  Amallar (ikonali) - ma'lumot bo'lmasa o'chiriladi  -->
                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Bottom"
                    Orientation="Horizontal">
                    <Button
                        Width="44"
                        Margin="0,0,8,0"
                        Padding="0"
                        Background="#6C5CE7"
                        Command="{Binding PreviewCommand}"
                        IsEnabled="{Binding CustomerOperationsForDisplay.Count, Converter={StaticResource CountToBool}}"
                        Style="{StaticResource ToolButton}"
                        ToolTip="Ko‘rish">
                        <fa:IconImage
                            Width="16"
                            Height="16"
                            Foreground="White"
                            Icon="Eye" />
                    </Button>
                    <Button
                        Width="44"
                        Margin="0,0,8,0"
                        Padding="0"
                        Background="#EC407A"
                        Command="{Binding PrintCommand}"
                        IsEnabled="{Binding CustomerOperationsForDisplay.Count, Converter={StaticResource CountToBool}}"
                        Style="{StaticResource ToolButton}"
                        ToolTip="Pechat">
                        <fa:IconImage
                            Width="16"
                            Height="16"
                            Foreground="White"
                            Icon="Print" />
                    </Button>
                    <Button
                        Width="44"
                        Padding="0"
                        Background="#1D8A4E"
                        Command="{Binding ExportToExcelCommand}"
                        IsEnabled="{Binding CustomerOperationsForDisplay.Count, Converter={StaticResource CountToBool}}"
                        Style="{StaticResource ToolButton}"
                        ToolTip="Excel">
                        <fa:IconImage
                            Width="16"
                            Height="16"
                            Foreground="White"
                            Icon="FileExcel" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid
            x:Name="MyDataGrid"
            Grid.Row="1"
            utils:DataGridRowNumbering.IsEnabled="True"
            AlternatingRowBackground="#F5F5F5"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            FontSize="14"
            HeadersVisibility="Column, Row"
            IsReadOnly="True"
            ItemsSource="{Binding CustomerOperationsForDisplay}"
            SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="0.7*"
                    Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}"
                    Header="Sana">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5,0" />
                            <Setter Property="TextAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                    <DataGridTextColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.HeaderStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Width="3*">
                    <DataGridTemplateColumn.Header>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontWeight="Bold"
                            Text="Izoh" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ContentPresenter Content="{Binding FormattedTextBlock}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                            <Setter Property="VerticalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTemplateColumn.HeaderStyle>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="0.7*">
                    <DataGridTemplateColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTemplateColumn.HeaderStyle>
                    <DataGridTemplateColumn.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock
                                FontWeight="Bold"
                                Foreground="DarkRed"
                                Text="Debit" />
                            <TextBlock
                                FontWeight="Bold"
                                Foreground="Black"
                                Text=" / " />
                            <TextBlock
                                FontWeight="Bold"
                                Foreground="Black"
                                Text="Kredit" />
                        </StackPanel>
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="5,0">
                                <TextBlock
                                    HorizontalAlignment="Right"
                                    Foreground="DarkRed"
                                    Text="{Binding Debit, StringFormat={}{0:N0}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Debit, Converter={x:Null}}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding OperationType}" Value="Sale">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Credit}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock
                                    HorizontalAlignment="Right"
                                    Foreground="Black"
                                    Text="{Binding Credit, StringFormat={}{0:N0}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Debit}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="100" Header="Amallar">
                    <DataGridTemplateColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="HorizontalContentAlignment" Value="Center" />
                        </Style>
                    </DataGridTemplateColumn.HeaderStyle>
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="5" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <StackPanel
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <Button
                                                Width="32"
                                                Height="28"
                                                Margin="2,0"
                                                Background="#FFB300"
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Foreground="White"
                                                IsEnabled="{Binding CanEdit}"
                                                ToolTip="Tahrirlash">
                                                <Path
                                                    Width="14"
                                                    Height="14"
                                                    Data="M3,17.25V21H6.75L17.81,9.94L14.06,6.19L3,17.25ZM20.71,7.04C21.1,6.65 21.1,6 20.71,5.61L18.37,3.29C17.98,2.9 17.33,2.9 16.94,3.29L15.12,5.12L18.87,8.87L20.71,7.04Z"
                                                    Fill="White"
                                                    Stretch="Uniform" />
                                            </Button>
                                            <Button
                                                Width="32"
                                                Height="28"
                                                Margin="2,0"
                                                Background="#E53935"
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Foreground="White"
                                                ToolTip="O‘chirish">
                                                <Path
                                                    Width="14"
                                                    Height="14"
                                                    Data="M6,19C6,20.1 6.9,21 8,21H16C17.1,21 18,20.1 18,19V7H6V19ZM19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4Z"
                                                    Fill="White"
                                                    Stretch="Uniform" />
                                            </Button>
                                        </StackPanel>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
