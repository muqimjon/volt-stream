<Window
    x:Class="VoltStream.WPF.Customer.CustomerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="clr-namespace:VoltStream.WPF.Commons.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:loc="clr-namespace:VoltStream.WPF.Commons.Localization"
    xmlns:local="clr-namespace:VoltStream.WPF.Customer"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:VoltStream.WPF.Commons.Utils"
    Title="{loc:Loc Customer.WindowTitle}"
    Width="440"
    Height="430"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    ResizeMode="NoResize"
    mc:Ignorable="d">

	<Border BorderBrush="{DynamicResource Border}" Margin="25"
            BorderThickness="1"
            Background="{DynamicResource Surface}"  CornerRadius="{DynamicResource RadiusLg}"
            Effect="{DynamicResource CardShadow}">

		<Grid Margin="10">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="120" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<Border Grid.Row="0" Grid.ColumnSpan="2"
                    Background="{DynamicResource SurfaceAlt}"
                    CornerRadius="{DynamicResource RadiusMd}"
                    Padding="12,6"
                    Margin="0,0,0,10">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<TextBlock VerticalAlignment="Center"
                               Style="{StaticResource SubtitleText}"
                               Text="{loc:Loc Customer.NewCustomerInfo}" />
					<Button Grid.Column="1"
                            Style="{StaticResource IconButton}"
                            Width="30" Height="30"
                            IsCancel="True"
                            ToolTip="{loc:Loc Common.Close}">
						<Path Width="12" Height="12"
                              Stroke="{DynamicResource TextSecondary}"
                              StrokeThickness="1.6"
                              Data="M0,0 L12,12 M12,0 L0,12" />
					</Button>
				</Grid>
			</Border>

			<TextBlock
                Grid.Row="1"
                Grid.Column="0"
                Margin="0,5"
                VerticalAlignment="Center"
                Text="{loc:Loc Customer.NameLabel}" />
			<TextBox
                x:Name="txtName"
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,5"
                Style="{StaticResource ModernTextBox}"
                utils:TextBoxTabBehavior.EnableTabOnKeys="True"
                FontSize="14" />
			<TextBlock
                Grid.Row="2"
                Grid.Column="0"
                Margin="0,5"
                VerticalAlignment="Center"
                Text="{loc:Loc Customer.PhoneLabel}" />
			<TextBox
                x:Name="txtPhone"
                Grid.Row="2"
                Grid.Column="1"
                Margin="0,5"
                Style="{StaticResource ModernTextBox}"
                utils:TextBoxTabBehavior.EnableTabOnKeys="True"
                FontSize="14" />
			<TextBlock
                Grid.Row="3"
                Grid.Column="0"
                Margin="0,5"
                VerticalAlignment="Center"
                Text="{loc:Loc Customer.AddressLabel}" />
			<TextBox
                x:Name="txtAddress"
                Grid.Row="3"
                Grid.Column="1"
                Margin="0,5"
                Style="{StaticResource ModernTextBox}"
                utils:TextBoxTabBehavior.EnableTabOnKeys="True"
                FontSize="14" />
			<TextBlock
                Grid.Row="4"
                Grid.Column="0"
                Margin="0,5"
                VerticalAlignment="Center"
                Text="{loc:Loc Customer.BeginningBalanceLabel}" />
			<Grid Grid.Row="4" Grid.Column="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<TextBlock
                    Grid.Column="0"
                    Margin="15,5"
                    Panel.ZIndex="1"
                    Foreground="{DynamicResource Danger}"
                    IsHitTestVisible="False"
                    Text="{loc:Loc Customer.DebtPlaceholder}"
                    Visibility="{Binding ElementName=txtBeginningSum, Path=Text.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />
				<TextBox
                    x:Name="txtBeginningSum"
                    Grid.Column="0"
                    Margin="0,5,3,5"
                    Style="{StaticResource ModernTextBox}"
                    utils:NumericInput.IsNumeric="True"
                    utils:TextBoxTabBehavior.EnableTabOnKeys="True"
                    FontSize="14"
                    Foreground="{DynamicResource Danger}"
                    Visibility="{Binding ElementName=txtBeginningSum2, Path=Text.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />
				<TextBlock
                    Grid.Column="1"
                    Margin="15,5"
                    Panel.ZIndex="1"
                    Foreground="{DynamicResource TextSecondary}"
                    IsHitTestVisible="False"
                    Text="{loc:Loc Customer.CreditPlaceholder}"
                    Visibility="{Binding ElementName=txtBeginningSum2, Path=Text.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />
				<TextBox
                    x:Name="txtBeginningSum2"
                    Grid.Column="1"
                    Margin="3,5,0,5"
                    Style="{StaticResource ModernTextBox}"
                    utils:NumericInput.IsNumeric="True"
                    utils:TextBoxTabBehavior.EnableTabOnKeys="True"
                    FontSize="14"
                    Visibility="{Binding ElementName=txtBeginningSum, Path=Text.IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />
			</Grid>
			<TextBlock
                Grid.Row="5"
                Grid.Column="0"
                Margin="0,5"
                VerticalAlignment="Center"
                Text="{loc:Loc Customer.AdditionalInfoLabel}" />
			<TextBox
                x:Name="txtDescription"
                Grid.Row="5"
                Grid.Column="1"
                Margin="0,5"
                Style="{StaticResource ModernTextBox}"
                utils:TextBoxTabBehavior.EnableTabOnKeys="True"
                FontSize="14" />
			<StackPanel
                Grid.Row="6"
                Grid.ColumnSpan="2"
                Margin="0,5,0,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal">
				<Button
                    Width="100"
                    Margin="5"
                    Style="{StaticResource PrimaryButton}"
                    Click="Save_Click"
                    Content="{loc:Loc Common.Save}" />
				<Button
                    Width="100"
                    Margin="5"
                    Style="{StaticResource SecondaryButton}"
                    Content="{loc:Loc Common.Cancel}"
                    IsCancel="True" />
			</StackPanel>
		</Grid>
	</Border>
</Window>