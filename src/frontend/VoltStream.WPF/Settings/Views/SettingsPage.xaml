<Page x:Name="RootPage"
      x:Class="VoltStream.WPF.Settings.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:modules="clr-namespace:VoltStream.WPF.Settings.Views.Modules"
      xmlns:controls="clr-namespace:VoltStream.WPF.Commons.UserControls"
      xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
      xmlns:loc="clr-namespace:VoltStream.WPF.Commons.Localization"
      Background="{DynamicResource Canvas}"
      Title="{loc:Loc Nav.Settings}">
	<Grid Margin="10">
		<TabControl x:Name="SettingsTabControl" FontSize="{DynamicResource FontSizeBody}" SelectionChanged="SettingsTabControl_SelectionChanged">

			<TabItem>
				<TabItem.Header>
					<StackPanel Orientation="Horizontal">
						<fa:IconImage Icon="Plug" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
						<TextBlock Text="{loc:Loc Settings.TabConnection}" VerticalAlignment="Center" />
					</StackPanel>
				</TabItem.Header>
				<modules:ConnectionSettingsView DataContext="{Binding ApiConnection}" />
			</TabItem>

			<TabItem>
				<TabItem.Header>
					<StackPanel Orientation="Horizontal">
						<fa:IconImage Icon="Coins" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
						<TextBlock Text="{loc:Loc Settings.TabCurrencies}" VerticalAlignment="Center" />
						<fa:IconImage Icon="Lock" Width="11" Height="11" Margin="8,0,0,0" VerticalAlignment="Center"
                                      Foreground="{DynamicResource TextTertiary}"
                                      Visibility="{Binding IsLocked, ElementName=CurrencyLock, Converter={StaticResource BooleanToVisibilityConverter}}" />
					</StackPanel>
				</TabItem.Header>
				<controls:AdminLockOverlay x:Name="CurrencyLock"
                                          DataContext="{Binding ElementName=RootPage, Path=DataContext}"
                                          LockMessage="{loc:Loc Settings.CurrencyLockMessage}">
					<controls:AdminLockOverlay.InnerContent>
						<modules:CurrencySettingsView />
					</controls:AdminLockOverlay.InnerContent>
				</controls:AdminLockOverlay>
			</TabItem>

			<TabItem>
				<TabItem.Header>
					<StackPanel Orientation="Horizontal">
						<fa:IconImage Icon="Tags" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
						<TextBlock Text="{loc:Loc Settings.TabCategories}" VerticalAlignment="Center" />
						<fa:IconImage Icon="Lock" Width="11" Height="11" Margin="8,0,0,0" VerticalAlignment="Center"
                                      Foreground="{DynamicResource TextTertiary}"
                                      Visibility="{Binding IsLocked, ElementName=CategoryLock, Converter={StaticResource BooleanToVisibilityConverter}}" />
					</StackPanel>
				</TabItem.Header>
				<controls:AdminLockOverlay x:Name="CategoryLock"
                                          DataContext="{Binding ElementName=RootPage, Path=DataContext.CategorySettings}"
                                          LockMessage="{loc:Loc Settings.CategoryLockMessage}">
					<controls:AdminLockOverlay.InnerContent>
						<modules:CategorySettingsView />
					</controls:AdminLockOverlay.InnerContent>
				</controls:AdminLockOverlay>
			</TabItem>

			<TabItem>
				<TabItem.Header>
					<StackPanel Orientation="Horizontal">
						<fa:IconImage Icon="Boxes" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
						<TextBlock Text="{loc:Loc Settings.TabProducts}" VerticalAlignment="Center" />
						<fa:IconImage Icon="Lock" Width="11" Height="11" Margin="8,0,0,0" VerticalAlignment="Center"
                                      Foreground="{DynamicResource TextTertiary}"
                                      Visibility="{Binding IsLocked, ElementName=ProductLock, Converter={StaticResource BooleanToVisibilityConverter}}" />
					</StackPanel>
				</TabItem.Header>
				<controls:AdminLockOverlay x:Name="ProductLock"
                                          DataContext="{Binding ElementName=RootPage, Path=DataContext.ProductSettings}"
                                          LockMessage="{loc:Loc Settings.ProductLockMessage}">
					<controls:AdminLockOverlay.InnerContent>
						<modules:ProductSettingsView />
					</controls:AdminLockOverlay.InnerContent>
				</controls:AdminLockOverlay>
			</TabItem>

			<TabItem>
				<TabItem.Header>
					<StackPanel Orientation="Horizontal">
						<fa:IconImage Icon="Users" Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"
                                      Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" />
						<TextBlock Text="{loc:Loc Settings.TabCustomers}" VerticalAlignment="Center" />
						<fa:IconImage Icon="Lock" Width="11" Height="11" Margin="8,0,0,0" VerticalAlignment="Center"
                                      Foreground="{DynamicResource TextTertiary}"
                                      Visibility="{Binding IsLocked, ElementName=CustomerLock, Converter={StaticResource BooleanToVisibilityConverter}}" />
					</StackPanel>
				</TabItem.Header>
				<controls:AdminLockOverlay x:Name="CustomerLock"
                                          DataContext="{Binding ElementName=RootPage, Path=DataContext.CustomerSettings}"
                                          LockMessage="{loc:Loc Settings.CustomerLockMessage}">
					<controls:AdminLockOverlay.InnerContent>
						<modules:CustomerSettingsView />
					</controls:AdminLockOverlay.InnerContent>
				</controls:AdminLockOverlay>
			</TabItem>

		</TabControl>
	</Grid>
</Page>