<Window x:Class="VoltStream.WPF.Settings.Views.ConnectionSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:VoltStream.WPF.Commons.Localization"
        Title="{loc:Loc Settings.ConnectionWindowTitle}"
        Height="580"
        Width="450"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True">

    <Border CornerRadius="12"
            Background="{DynamicResource Surface}"
            BorderBrush="{DynamicResource Border}"
            BorderThickness="1"
            Effect="{DynamicResource CardShadow}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{loc:Loc Settings.ConnectionHeader}"
                           Grid.Column="0"
                           Style="{StaticResource CaptionText}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>

                <Button x:Name="btnClose"
                        Grid.Column="1"
                        Content="✕"
                        FontSize="14"
                        Foreground="{DynamicResource TextSecondary}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnClose_Click"
                        VerticalAlignment="Center"
                        Width="32"
                        Height="32"
                        Margin="0,0,8,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource Danger}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Margin="24,8,24,0">

                <!-- Status Display -->
                <Border Background="{DynamicResource SurfaceAlt}"
                        CornerRadius="{DynamicResource RadiusMd}"
                        Padding="15"
                        Margin="0,0,0,20"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource Border}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="{loc:Loc Settings.StatusLabel}"
                                       Foreground="{DynamicResource TextSecondary}"/>
                            <TextBlock Text="{Binding ApiConnection.StatusText}"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <TextBlock Text="{Binding ApiConnection.Url}"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="{DynamicResource FontSizeCaption}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- URL Configuration -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Settings.ServerAddress}" Style="{StaticResource SubtitleText}" Margin="0,0,0,12"/>

                        <CheckBox Content="{loc:Loc Settings.UseHttps}"
                                  Style="{StaticResource ModernCheck}"
                                  IsChecked="{Binding ApiConnection.IsHttps, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,0,12"/>

                        <TextBlock Text="{loc:Loc Settings.Host}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="HostTextBox"
                                 Style="{StaticResource ModernTextBox}"
                                 Text="{Binding ApiConnection.Host, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <TextBlock Text="{loc:Loc Settings.Port}" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="PortTextBox"
                                 Style="{StaticResource ModernTextBox}"
                                 Text="{Binding ApiConnection.Port, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Border>

                <!-- Error/Success Messages -->
                <TextBlock Text="{Binding Error}"
                           Foreground="{DynamicResource Danger}"
                           FontSize="{DynamicResource FontSizeCaption}"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0"
                           Visibility="{Binding Error, Converter={StaticResource StringToVisibilityConverter}}"/>

                <TextBlock Text="{Binding Success}"
                           Foreground="{DynamicResource Success}"
                           FontSize="{DynamicResource FontSizeCaption}"
                           TextWrapping="Wrap"
                           Margin="0,15,0,0"
                           Visibility="{Binding Success, Converter={StaticResource StringToVisibilityConverter}}"/>

                <TextBlock Text="{Binding Warning}"
                           Foreground="{DynamicResource Warning}"
                           FontSize="{DynamicResource FontSizeCaption}"
                           TextWrapping="Wrap"
                           Margin="0,15,0,0"
                           Visibility="{Binding Warning, Converter={StaticResource StringToVisibilityConverter}}"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,16,0,20">

                <Button Content="{loc:Loc Settings.TestUpper}"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding TestConnectionCommand}"
                        Width="140"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolToBoolConverter}}"
                        Margin="5,0"/>

                <Button Content="{loc:Loc Settings.SaveUpper}"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveAndCloseCommand}"
                        Width="140"
                        Margin="5,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>