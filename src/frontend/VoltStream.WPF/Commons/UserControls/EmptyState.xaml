<UserControl
    x:Class="VoltStream.WPF.Commons.UserControls.EmptyState"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
    x:Name="root">
    <StackPanel
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Orientation="Vertical">
        <fa:IconImage
            Width="44"
            Height="44"
            HorizontalAlignment="Center"
            Foreground="{DynamicResource TextTertiary}"
            Icon="{Binding Icon, ElementName=root}" />
        <TextBlock
            Margin="0,14,0,0"
            HorizontalAlignment="Center"
            FontSize="{DynamicResource FontSizeSubtitle}"
            Foreground="{DynamicResource TextSecondary}"
            Text="{Binding Message, ElementName=root}" />
    </StackPanel>
</UserControl>
