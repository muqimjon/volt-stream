<UserControl
    x:Class="VoltStream.WPF.Commons.UserControls.Pager"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp">
    <StackPanel
        HorizontalAlignment="Right"
        VerticalAlignment="Center"
        Orientation="Horizontal">
        <TextBlock
            Margin="0,0,8,0"
            VerticalAlignment="Center"
            FontSize="{DynamicResource FontSizeCaption}"
            Foreground="{DynamicResource TextSecondary}"
            Text="Sahifada:" />
        <ComboBox
            Width="68"
            Margin="0,0,16,0"
            VerticalAlignment="Center"
            ItemsSource="{Binding PageSizeOptions}"
            SelectedItem="{Binding PageSize, Mode=TwoWay}"
            Style="{DynamicResource ModernCombo}" />
        <TextBlock
            Margin="0,0,16,0"
            VerticalAlignment="Center"
            FontSize="{DynamicResource FontSizeCaption}"
            Foreground="{DynamicResource TextSecondary}"
            Text="{Binding Summary}" />
        <Button
            Margin="2,0"
            Command="{Binding FirstCommand}"
            Style="{DynamicResource IconButton}"
            ToolTip="Birinchi sahifa">
            <fa:IconImage Width="13" Height="13" Foreground="{DynamicResource TextSecondary}" Icon="AnglesLeft" />
        </Button>
        <Button
            Margin="2,0"
            Command="{Binding PreviousCommand}"
            Style="{DynamicResource IconButton}"
            ToolTip="Oldingi">
            <fa:IconImage Width="13" Height="13" Foreground="{DynamicResource TextSecondary}" Icon="AngleLeft" />
        </Button>
        <Border
            MinWidth="66"
            Margin="6,0"
            Padding="10,7"
            Background="{DynamicResource SurfaceAlt}"
            CornerRadius="{DynamicResource RadiusMd}">
            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontWeight="SemiBold"
                Foreground="{DynamicResource TextPrimary}">
                <Run Text="{Binding Page, Mode=OneWay}" /><Run Text=" / " /><Run Text="{Binding TotalPages, Mode=OneWay}" />
            </TextBlock>
        </Border>
        <Button
            Margin="2,0"
            Command="{Binding NextCommand}"
            Style="{DynamicResource IconButton}"
            ToolTip="Keyingi">
            <fa:IconImage Width="13" Height="13" Foreground="{DynamicResource TextSecondary}" Icon="AngleRight" />
        </Button>
        <Button
            Margin="2,0"
            Command="{Binding LastCommand}"
            Style="{DynamicResource IconButton}"
            ToolTip="Oxirgi sahifa">
            <fa:IconImage Width="13" Height="13" Foreground="{DynamicResource TextSecondary}" Icon="AnglesRight" />
        </Button>
    </StackPanel>
</UserControl>
