<UserControl
    x:Class="VoltStream.WPF.Commons.UserControls.BusyOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="root"
    Visibility="{Binding IsBusy, ElementName=root, Converter={StaticResource BooleanToVisibilityConverter}}">
    <Border Background="{DynamicResource Surface}" Opacity="0.78">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Vertical">
            <Border
                x:Name="spinnerHost"
                Width="44"
                Height="44"
                HorizontalAlignment="Center"
                RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <RotateTransform x:Name="spin" />
                </Border.RenderTransform>
                <Path
                    Data="M22,4 A18,18 0 1 1 4,22"
                    Stroke="{DynamicResource Brand}"
                    StrokeEndLineCap="Round"
                    StrokeThickness="4" />
            </Border>
            <TextBlock
                Margin="0,12,0,0"
                HorizontalAlignment="Center"
                Foreground="{DynamicResource TextSecondary}"
                Text="{Binding Message, ElementName=root}" />
        </StackPanel>
        <Border.Triggers>
            <EventTrigger RoutedEvent="Border.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation
                            RepeatBehavior="Forever"
                            Storyboard.TargetName="spin"
                            Storyboard.TargetProperty="Angle"
                            From="0"
                            To="360"
                            Duration="0:0:1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>
    </Border>
</UserControl>
