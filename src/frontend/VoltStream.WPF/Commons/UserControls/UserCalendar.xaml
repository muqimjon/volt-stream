<UserControl
    x:Class="VoltStream.WPF.Commons.UserControls.UserCalendar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
    xmlns:local="clr-namespace:VoltStream.WPF.Commons.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Border
        x:Name="RootBorder"
        Height="38"
        VerticalAlignment="Center"
        Background="{DynamicResource Surface}"
        BorderBrush="{DynamicResource BorderStrong}"
        BorderThickness="1.5"
        CornerRadius="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="34" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="TextBox"
                Grid.Column="0"
                Margin="0"
                Padding="8,0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                CaretBrush="{DynamicResource TextPrimary}"
                FontSize="14"
                Foreground="{DynamicResource TextPrimary}" />

            <Button
                Grid.Column="1"
                Click="OpenCalendar_Click"
                Cursor="Hand"
                IsTabStop="False">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="bd"
                            Background="Transparent"
                            CornerRadius="0,7,7,0">
                            <fa:IconImage
                                Width="15"
                                Height="15"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource TextSecondary}"
                                Icon="CalendarDays" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource BrandSubtle}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Popup
                x:Name="Popup"
                AllowsTransparency="True"
                Placement="Bottom"
                PlacementTarget="{Binding ElementName=RootBorder}"
                PopupAnimation="Slide"
                StaysOpen="False">
                <Border
                    Margin="0,6,4,4"
                    Padding="4"
                    Background="{DynamicResource Surface}"
                    BorderBrush="{DynamicResource Border}"
                    BorderThickness="1"
                    CornerRadius="10">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="16"
                            Opacity="0.2"
                            ShadowDepth="3"
                            Color="#555555" />
                    </Border.Effect>
                    <Calendar
                        x:Name="calendar"
                        Background="{DynamicResource Surface}"
                        Foreground="{DynamicResource TextPrimary}"
                        SelectedDatesChanged="Calendar_SelectedDatesChanged" />
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
