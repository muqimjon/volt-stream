<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <FontFamily x:Key="AppFontFamily">Segoe UI</FontFamily>

    <sys:Double x:Key="FontSizeCaption">12</sys:Double>
    <sys:Double x:Key="FontSizeBody">14</sys:Double>
    <sys:Double x:Key="FontSizeSubtitle">16</sys:Double>
    <sys:Double x:Key="FontSizeTitle">20</sys:Double>
    <sys:Double x:Key="FontSizeDisplay">28</sys:Double>

    <sys:Double x:Key="SpaceXs">4</sys:Double>
    <sys:Double x:Key="SpaceSm">8</sys:Double>
    <sys:Double x:Key="SpaceMd">12</sys:Double>
    <sys:Double x:Key="SpaceLg">16</sys:Double>
    <sys:Double x:Key="SpaceXl">24</sys:Double>
    <sys:Double x:Key="SpaceXxl">32</sys:Double>

    <Thickness x:Key="PagePadding">18</Thickness>
    <Thickness x:Key="CardPadding">16</Thickness>
    <Thickness x:Key="FieldPadding">10,0</Thickness>

    <CornerRadius x:Key="RadiusSm">6</CornerRadius>
    <CornerRadius x:Key="RadiusMd">8</CornerRadius>
    <CornerRadius x:Key="RadiusLg">12</CornerRadius>
    <CornerRadius x:Key="RadiusPill">999</CornerRadius>

    <sys:Double x:Key="ControlHeight">38</sys:Double>
    <sys:Double x:Key="RowHeight">36</sys:Double>

    <DropShadowEffect
        x:Key="CardShadow"
        BlurRadius="18"
        Direction="270"
        Opacity="0.10"
        ShadowDepth="2"
        Color="#1F2937" />

    <DropShadowEffect
        x:Key="PopupShadow"
        BlurRadius="14"
        Direction="270"
        Opacity="0.18"
        ShadowDepth="2"
        Color="#555555" />

</ResourceDictionary>
