<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  ===== Semantic colors ===== -->
    <Color x:Key="BrandColor">#4F46E5</Color>
    <Color x:Key="BrandHoverColor">#4338CA</Color>
    <Color x:Key="BrandPressedColor">#3730A3</Color>
    <Color x:Key="BrandSubtleColor">#EEF0FE</Color>
    <Color x:Key="OnBrandColor">#FFFFFF</Color>

    <Color x:Key="CanvasColor">#EEF1F6</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceAltColor">#F6F8FC</Color>

    <Color x:Key="BorderColor">#E5E8EF</Color>
    <Color x:Key="BorderStrongColor">#D0D5DD</Color>
    <Color x:Key="BorderHoverColor">#B0B6C0</Color>
    <Color x:Key="FocusColor">#4F46E5</Color>

    <Color x:Key="TextPrimaryColor">#1F2937</Color>
    <Color x:Key="TextSecondaryColor">#6B7280</Color>
    <Color x:Key="TextTertiaryColor">#9AA4B2</Color>
    <Color x:Key="TextDisabledColor">#B8BEC9</Color>
    <Color x:Key="DisabledBgColor">#F2F4F7</Color>

    <Color x:Key="SuccessColor">#16A34A</Color>
    <Color x:Key="SuccessSubtleColor">#E9F8EE</Color>
    <Color x:Key="DangerColor">#DC2626</Color>
    <Color x:Key="DangerSubtleColor">#FDECEC</Color>
    <Color x:Key="WarningColor">#D97706</Color>
    <Color x:Key="WarningSubtleColor">#FFF6E6</Color>
    <Color x:Key="InfoColor">#2563EB</Color>
    <Color x:Key="InfoSubtleColor">#EAF1FE</Color>

    <Color x:Key="SidebarBgColor">#FFFFFF</Color>
    <Color x:Key="SidebarBorderColor">#E5E8EF</Color>
    <Color x:Key="SidebarItemTextColor">#5A6477</Color>
    <Color x:Key="SidebarItemTextActiveColor">#4F46E5</Color>
    <Color x:Key="SidebarItemActiveBgColor">#EEF0FE</Color>
    <Color x:Key="SidebarItemHoverBgColor">#F2F4F9</Color>

    <Color x:Key="HeaderBgColor">#FFFFFF</Color>
    <Color x:Key="HeaderTextColor">#1F2937</Color>

    <!--  ===== Semantic brushes ===== -->
    <SolidColorBrush x:Key="Brand" Color="{StaticResource BrandColor}" />
    <SolidColorBrush x:Key="BrandHover" Color="{StaticResource BrandHoverColor}" />
    <SolidColorBrush x:Key="BrandPressed" Color="{StaticResource BrandPressedColor}" />
    <SolidColorBrush x:Key="BrandSubtle" Color="{StaticResource BrandSubtleColor}" />
    <SolidColorBrush x:Key="OnBrand" Color="{StaticResource OnBrandColor}" />

    <SolidColorBrush x:Key="Canvas" Color="{StaticResource CanvasColor}" />
    <SolidColorBrush x:Key="Surface" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="SurfaceAlt" Color="{StaticResource SurfaceAltColor}" />
    <SolidColorBrush x:Key="Card" Color="{StaticResource SurfaceColor}" />

    <SolidColorBrush x:Key="Border" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderStrong" Color="{StaticResource BorderStrongColor}" />
    <SolidColorBrush x:Key="BorderHover" Color="{StaticResource BorderHoverColor}" />
    <SolidColorBrush x:Key="Focus" Color="{StaticResource FocusColor}" />

    <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiary" Color="{StaticResource TextTertiaryColor}" />
    <SolidColorBrush x:Key="TextDisabled" Color="{StaticResource TextDisabledColor}" />
    <SolidColorBrush x:Key="DisabledBg" Color="{StaticResource DisabledBgColor}" />

    <SolidColorBrush x:Key="Success" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="SuccessSubtle" Color="{StaticResource SuccessSubtleColor}" />
    <SolidColorBrush x:Key="Danger" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="DangerSubtle" Color="{StaticResource DangerSubtleColor}" />
    <SolidColorBrush x:Key="Warning" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="WarningSubtle" Color="{StaticResource WarningSubtleColor}" />
    <SolidColorBrush x:Key="Info" Color="{StaticResource InfoColor}" />
    <SolidColorBrush x:Key="InfoSubtle" Color="{StaticResource InfoSubtleColor}" />

    <SolidColorBrush x:Key="SidebarBg" Color="{StaticResource SidebarBgColor}" />
    <SolidColorBrush x:Key="SidebarBorder" Color="{StaticResource SidebarBorderColor}" />
    <SolidColorBrush x:Key="SidebarItemText" Color="{StaticResource SidebarItemTextColor}" />
    <SolidColorBrush x:Key="SidebarItemTextActive" Color="{StaticResource SidebarItemTextActiveColor}" />
    <SolidColorBrush x:Key="SidebarItemActiveBg" Color="{StaticResource SidebarItemActiveBgColor}" />
    <SolidColorBrush x:Key="SidebarItemHoverBg" Color="{StaticResource SidebarItemHoverBgColor}" />

    <SolidColorBrush x:Key="HeaderBg" Color="{StaticResource HeaderBgColor}" />
    <SolidColorBrush x:Key="HeaderText" Color="{StaticResource HeaderTextColor}" />

    <!--  ===== Legacy keys (theme-aware so existing styles adapt) ===== -->
    <SolidColorBrush x:Key="plainTextColor1" Color="{StaticResource SidebarItemTextColor}" />
    <SolidColorBrush x:Key="plainTextColor2" Color="{StaticResource TextTertiaryColor}" />
    <SolidColorBrush x:Key="plainTextColor3" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="titleColor1" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="titleColor2" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="titleColor3" Color="{StaticResource SidebarItemTextActiveColor}" />
    <SolidColorBrush x:Key="panelColor" Color="{StaticResource SidebarBgColor}" />
    <SolidColorBrush x:Key="panelOverColor" Color="{StaticResource SidebarItemHoverBgColor}" />
    <SolidColorBrush x:Key="panelActiveColor" Color="{StaticResource SidebarItemActiveBgColor}" />

    <SolidColorBrush x:Key="color1" Color="{StaticResource BrandColor}" />
    <SolidColorBrush x:Key="color2" Color="{StaticResource BrandColor}" />
    <SolidColorBrush x:Key="color3" Color="{StaticResource BrandColor}" />
    <SolidColorBrush x:Key="color4" Color="{StaticResource BrandColor}" />
    <SolidColorBrush x:Key="color5" Color="{StaticResource BrandColor}" />
    <SolidColorBrush x:Key="color6" Color="{StaticResource BrandColor}" />
    <SolidColorBrush x:Key="color7" Color="{StaticResource BrandColor}" />
    <SolidColorBrush x:Key="color8" Color="{StaticResource BrandColor}" />
    <SolidColorBrush x:Key="color9" Color="{StaticResource BrandColor}" />
    <SolidColorBrush x:Key="color10" Color="{StaticResource BrandColor}" />

    <Color x:Key="winBorderColor1">#4F46E5</Color>
    <Color x:Key="winBorderColor2">#6366F1</Color>
    <Color x:Key="winBorderColor3">#818CF8</Color>
    <Color x:Key="primaryBackColor1">#EEF1F6</Color>
    <Color x:Key="primaryBackColor2">#FFFFFF</Color>
    <Color x:Key="secondaryBackColor1">#F6F8FC</Color>
    <Color x:Key="secondaryBackColor2">#F6F8FC</Color>

</ResourceDictionary>
