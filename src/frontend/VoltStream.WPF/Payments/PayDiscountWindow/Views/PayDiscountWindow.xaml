<Window
    x:Class="VoltStream.WPF.Payments.PayDiscountWindow.Views.PayDiscountWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:loc="clr-namespace:VoltStream.WPF.Commons.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utils="clr-namespace:VoltStream.WPF.Commons.Utils"
    xmlns:viewModels="clr-namespace:VoltStream.WPF.Commons.ViewModels"
    Title="{loc:Loc Payments.DiscountWindowTitle}"
    SizeToContent="WidthAndHeight"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    ResizeMode="NoResize"
    mc:Ignorable="d">


	<Border BorderBrush="{DynamicResource Border}" Margin="25"
            BorderThickness="1"
            Background="{DynamicResource Surface}"  CornerRadius="{DynamicResource RadiusLg}"
            Effect="{DynamicResource CardShadow}">
		<Grid Margin="10">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="120" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>


			<Border Grid.Row="0" Grid.ColumnSpan="2"
                    Background="{DynamicResource SurfaceAlt}"
                    CornerRadius="{DynamicResource RadiusMd}"
                    Padding="12,6"
                    Margin="0,0,0,10">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>
					<TextBlock VerticalAlignment="Center"
                               Style="{StaticResource SubtitleText}"
                               Text="{loc:Loc Payments.UsingDiscount}" />
					<Button Grid.Column="1"
                            Style="{StaticResource IconButton}"
                            Width="30" Height="30"
                            IsCancel="True"
                            ToolTip="{loc:Loc Common.Close}">
						<Path Width="12" Height="12"
                              Stroke="{DynamicResource TextSecondary}"
                              StrokeThickness="1.6"
                              Data="M0,0 L12,12 M12,0 L0,12" />
					</Button>
				</Grid>
			</Border>

			<TextBlock
            Grid.Row="1"
            Margin="0,5"
            VerticalAlignment="Center"
            Text="{loc:Loc Payments.CustomerLabel}" />

			<TextBox
            x:Name="txtCustomer"
            Grid.Row="1"
            Grid.Column="1"
            Margin="0,5"
            Style="{StaticResource ReadOnlyValue}"
            utils:TextBoxTabBehavior.EnableTabOnKeys="True"
            FontSize="14"
            IsEnabled="False" />

			<TextBlock
            Grid.Row="2"
            Grid.Column="0"
            Margin="0,5"
            VerticalAlignment="Center"
            Text="{loc:Loc Payments.TotalBonuses}" />

			<TextBox
            x:Name="AmauntDiscount"
            Grid.Row="2"
            Grid.Column="1"
            Margin="0,5"
            Style="{StaticResource ReadOnlyValue}"
            utils:NumericInput.IsNumeric="True"
            utils:TextBoxTabBehavior.EnableTabOnKeys="True"
            FontSize="14"
            IsEnabled="False" />

			<TextBlock
            Grid.Row="3"
            Grid.Column="0"
            Margin="0,5"
            VerticalAlignment="Center"
            Text="{loc:Loc Payments.UsageAmount}" />

			<Grid Grid.Row="3" Grid.Column="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<TextBox
                x:Name="DiscountSum"
                Grid.Column="0"
                Margin="0,5"
                Style="{StaticResource ModernTextBox}"
                utils:NumericInput.IsNumeric="True"
                utils:TextBoxTabBehavior.EnableTabOnKeys="True"
                FontSize="14" />
				<Button
                Grid.Column="1"
                Margin="3,5,0,6"
                Padding="12,0"
                Style="{StaticResource SecondaryButton}"
                Click="Button_Click"
                Content="Σ"
                IsTabStop="False" />
			</Grid>

			<TextBlock
            Grid.Row="4"
            Grid.Column="0"
            Margin="0,5"
            VerticalAlignment="Center"
            Text="{loc:Loc Payments.Usage}" />
			<Grid Grid.Row="4" Grid.Column="1">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>

				<RadioButton
                x:Name="inCash"
                Grid.Column="0"
                Margin="0,5,3,5"
                Content="{loc:Loc Payments.InCash}"
                FontSize="14"
                Foreground="{DynamicResource Danger}" />


				<RadioButton
                x:Name="reCalculation"
                Grid.Column="1"
                Margin="3,5,0,5"
                Content="{loc:Loc Payments.Recalculation}"
                FontSize="14" />
			</Grid>

			<TextBlock
            Grid.Row="5"
            Grid.Column="0"
            Margin="0,5"
            VerticalAlignment="Center"
            Text="{loc:Loc Payments.NoteLabel}" />
			<TextBox
            x:Name="txtDescription"
            Grid.Row="5"
            Grid.Column="1"
            Margin="0,5"
            Style="{StaticResource ModernTextBox}"
            utils:TextBoxTabBehavior.EnableTabOnKeys="True"
            FontSize="14" />

			<StackPanel
            Grid.Row="6"
            Grid.Column="1"
            Margin="0,5,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
				<Button
                x:Name="SaveDiscount"
                Width="100"
                Margin="5"
                Style="{StaticResource PrimaryButton}"
                Click="SaveDiscount_Click"
                Content="{loc:Loc Common.Save}" />
				<Button
                Width="100"
                Margin="5"
                Style="{StaticResource SecondaryButton}"
                Content="{loc:Loc Common.Cancel}"
                IsCancel="True" />
			</StackPanel>
		</Grid>
	</Border>
</Window>
