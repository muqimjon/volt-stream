<Page x:Class="VoltStream.WPF.Home.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:VoltStream.WPF.Home.Views"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1100"
      Title="DashboardPage"
      Background="#F4F5FA">

    <Page.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderBrush" Value="#E6E8EF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="6" />
        </Style>

        <Style x:Key="Caption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8A94A6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#0A003A" />
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,8,0,0" />
        </Style>

        <Style x:Key="SubText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#636E72" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#0A003A" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="MiniStat" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FC" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="MinWidth" Value="150" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
        <StackPanel Margin="6">

            <!-- Sarlavha + Yangilash -->
            <Grid Margin="6,4,6,10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Boshqaruv paneli" FontSize="22" FontWeight="Bold" Foreground="#0A003A" />
                    <TextBlock Text="Yuklanmoqda..." Margin="14,0,0,0" VerticalAlignment="Center"
                               Foreground="#6C5CE7" FontWeight="SemiBold"
                               Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
                <Button Content="↻ Yangilash"
                        Command="{Binding RefreshCommand}"
                        HorizontalAlignment="Right"
                        Padding="14,7"
                        Background="#0A003A"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- KPI kartalar -->
            <UniformGrid Columns="4">
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Bugungi savdo" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding TodaySalesAmount, StringFormat={}{0:N0}}" Style="{StaticResource Value}" />
                        <TextBlock Style="{StaticResource SubText}"
                                   Text="{Binding TodaySalesCount, StringFormat=Soni: {0}}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Bugun sotilgan (uzunlik)" Style="{StaticResource Caption}" />
                        <TextBlock Style="{StaticResource Value}"
                                   Text="{Binding TodaySalesLength, StringFormat={}{0:N0} m}" />
                        <TextBlock Text="Bugungi kunda" Style="{StaticResource SubText}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Bu oylik savdo" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding MonthSalesAmount, StringFormat={}{0:N0}}" Style="{StaticResource Value}" />
                        <TextBlock Style="{StaticResource SubText}"
                                   Text="{Binding MonthSalesLength, StringFormat={}{0:N0} m}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Bugungi to'lovlar" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding TodayPaymentsAmount, StringFormat={}{0:N0}}" Style="{StaticResource Value}" />
                        <TextBlock Style="{StaticResource SubText}"
                                   Text="{Binding TodayPaymentsCount, StringFormat=Soni: {0}}" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Valyuta va bozor narxlari (CBU + investing.com) -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Valyuta va bozor narxlari" Style="{StaticResource SectionTitle}" Margin="0" />
                        <TextBlock Text="{Binding RateDate, StringFormat=CBU: {0}}" HorizontalAlignment="Right"
                                   Foreground="#8A94A6" FontSize="12" VerticalAlignment="Center" />
                    </Grid>
                    <WrapPanel>
                        <!-- USD -->
                        <Border Style="{StaticResource MiniStat}">
                            <StackPanel>
                                <TextBlock Text="USD (so'm)" Style="{StaticResource Caption}" />
                                <TextBlock Text="{Binding UsdRate, StringFormat={}{0:N2}}" FontSize="20"
                                           FontWeight="Bold" Foreground="#0A003A" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding UsdDiff, StringFormat={}{0:+#,##0.00;-#,##0.00;0}}" FontSize="12" Margin="0,2,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#E17055" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UsdUp}" Value="True">
                                                    <Setter Property="Foreground" Value="#00B894" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <!-- EUR -->
                        <Border Style="{StaticResource MiniStat}">
                            <StackPanel>
                                <TextBlock Text="EUR (so'm)" Style="{StaticResource Caption}" />
                                <TextBlock Text="{Binding EurRate, StringFormat={}{0:N2}}" FontSize="20"
                                           FontWeight="Bold" Foreground="#0A003A" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding EurDiff, StringFormat={}{0:+#,##0.00;-#,##0.00;0}}" FontSize="12" Margin="0,2,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#E17055" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding EurUp}" Value="True">
                                                    <Setter Property="Foreground" Value="#00B894" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <!-- Metallar (investing.com) -->
                        <ItemsControl ItemsSource="{Binding Metals}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource MiniStat}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" Style="{StaticResource Caption}" />
                                            <TextBlock Text="{Binding Price}" FontSize="20" FontWeight="Bold"
                                                       Foreground="#0A003A" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding ChangePercent}" FontSize="12" Margin="0,2,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#E17055" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUp}" Value="True">
                                                                <Setter Property="Foreground" Value="#00B894" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </WrapPanel>
                    <TextBlock Text="Manba: Markaziy bank (kurs) va investing.com (metall narxlari, jahon bozori)"
                               Foreground="#A0A6B4" FontSize="11" Margin="4,8,0,0" />
                </StackPanel>
            </Border>

            <!-- Oxirgi 7 kunlik savdo - chiziqli grafik -->
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Oxirgi 7 kunlik savdo" Style="{StaticResource SectionTitle}" />
                    <Viewbox Height="200" Stretch="Uniform" HorizontalAlignment="Center">
                        <Grid Width="660" Height="172">
                            <!-- chiziq tagidagi gradient maydon -->
                            <Polygon Points="{Binding WeeklyAreaPoints}">
                                <Polygon.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="#556C5CE7" />
                                        <GradientStop Offset="1" Color="#006C5CE7" />
                                    </LinearGradientBrush>
                                </Polygon.Fill>
                            </Polygon>
                            <!-- chiziq -->
                            <Polyline Points="{Binding WeeklyLinePoints}" Stroke="#6C5CE7"
                                      StrokeThickness="2.5" StrokeLineJoin="Round" />
                            <!-- nuqtalar (hoverda summa ko'rinadi) -->
                            <ItemsControl ItemsSource="{Binding WeeklyPoints}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                                        <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Canvas>
                                            <Ellipse Canvas.Left="-4.5" Canvas.Top="-4.5" Width="9" Height="9"
                                                     Fill="White" Stroke="#6C5CE7" StrokeThickness="2"
                                                     ToolTip="{Binding AmountText}" />
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- kun yorliqlari (nuqtalar bilan bir tekisda) -->
                            <ItemsControl ItemsSource="{Binding WeeklyPoints}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}" />
                                        <Setter Property="Canvas.Top" Value="156" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Canvas>
                                            <TextBlock Canvas.Left="-25" Width="50" TextAlignment="Center"
                                                       Text="{Binding DayLabel}" FontSize="11" Foreground="#636E72" />
                                        </Canvas>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Viewbox>
                </StackPanel>
            </Border>

            <!-- TOP mijozlar + TOP sotilayotgan mahsulotlar -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="TOP 5 mijoz (savdo bo'yicha)" Style="{StaticResource SectionTitle}" />
                        <ItemsControl ItemsSource="{Binding TopCustomers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6">
                                        <TextBlock Text="{Binding Customer}" FontSize="14" Foreground="#2D3436"
                                                   TextTrimming="CharacterEllipsis" Margin="0,0,110,0" />
                                        <TextBlock Text="{Binding Amount, StringFormat={}{0:N0}}" FontSize="14"
                                                   FontWeight="Bold" Foreground="#00B894" HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="TOP 5 sotilayotgan mahsulot" Style="{StaticResource SectionTitle}" />
                        <ItemsControl ItemsSource="{Binding TopSellingProducts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,6">
                                        <TextBlock Text="{Binding Product}" FontSize="14" Foreground="#2D3436"
                                                   TextTrimming="CharacterEllipsis" Margin="0,0,110,0" />
                                        <TextBlock Text="{Binding TotalLength, StringFormat={}{0:N0} m}" FontSize="14"
                                                   FontWeight="Bold" Foreground="#0A003A" HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
