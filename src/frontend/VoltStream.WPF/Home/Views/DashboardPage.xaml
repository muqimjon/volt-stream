<Page x:Class="VoltStream.WPF.Home.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:VoltStream.WPF.Home.Views"
      xmlns:loc="clr-namespace:VoltStream.WPF.Commons.Localization"
      xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
      xmlns:uc="clr-namespace:VoltStream.WPF.Commons.UserControls"
      xmlns:charts="clr-namespace:VoltStream.WPF.Home.Controls"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="1100"
      Title="DashboardPage"
      Background="{DynamicResource Canvas}">

    <Page.Resources>
        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="FontSize" Value="{DynamicResource FontSizeDisplay}" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,8,0,0" />
        </Style>

        <Style x:Key="MiniStat" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceAlt}" />
            <Setter Property="CornerRadius" Value="{DynamicResource RadiusMd}" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="MinWidth" Value="150" />
        </Style>

        <Style x:Key="Segment" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="18,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent"
                                CornerRadius="{DynamicResource RadiusSm}" Padding="{TemplateBinding Padding}">
                            <TextBlock x:Name="txt" Text="{TemplateBinding Content}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondary}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brand}" />
                                <Setter TargetName="txt" Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
            <StackPanel Margin="6">

                <Grid Margin="6,4,6,10">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{loc:Loc Dashboard.Title}" Style="{StaticResource TitleText}" />
                        <TextBlock Text="{loc:Loc Common.Loading}" Margin="14,0,0,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource Brand}" FontWeight="SemiBold"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="{DynamicResource SurfaceAlt}"
                                BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                CornerRadius="{DynamicResource RadiusMd}" Padding="3" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="{loc:Loc Dashboard.Day}" GroupName="Interval" Style="{StaticResource Segment}"
                                             IsChecked="{Binding Interval, Converter={StaticResource EnumToBoolean}, ConverterParameter=Day}" />
                                <RadioButton Content="{loc:Loc Dashboard.Week}" GroupName="Interval" Style="{StaticResource Segment}"
                                             IsChecked="{Binding Interval, Converter={StaticResource EnumToBoolean}, ConverterParameter=Week}" />
                                <RadioButton Content="{loc:Loc Dashboard.Month}" GroupName="Interval" Style="{StaticResource Segment}"
                                             IsChecked="{Binding Interval, Converter={StaticResource EnumToBoolean}, ConverterParameter=Month}" />
                            </StackPanel>
                        </Border>
                        <Button Command="{Binding RefreshCommand}"
                                Style="{StaticResource PrimaryButton}">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Width="14" Height="14" VerticalAlignment="Center"
                                              Foreground="{DynamicResource OnBrand}" Icon="ArrowsRotate" />
                                <TextBlock Margin="8,0,0,0" VerticalAlignment="Center"
                                           Foreground="{DynamicResource OnBrand}" Text="{loc:Loc Common.Refresh}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <WrapPanel>
                    <Border Style="{StaticResource CardBorder}" Margin="6" MinWidth="220">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Dashboard.TodaySales}" Style="{StaticResource CaptionText}" />
                            <TextBlock Text="{Binding TodaySalesAmount, StringFormat={}{0:N0}}" Style="{StaticResource Value}" />
                            <TextBlock Style="{StaticResource CaptionText}" Margin="0,4,0,0">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0}: {1}">
                                        <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="[Common.Quantity]" />
                                        <Binding Path="TodaySalesCount" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Margin="6" MinWidth="220">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Dashboard.TodaySoldLength}" Style="{StaticResource CaptionText}" />
                            <TextBlock Style="{StaticResource Value}"
                                       Text="{Binding TodaySalesLength, StringFormat={}{0:N0} m}" />
                            <TextBlock Text="{loc:Loc Dashboard.Today}" Style="{StaticResource CaptionText}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Margin="6" MinWidth="220">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Dashboard.MonthSales}" Style="{StaticResource CaptionText}" />
                            <TextBlock Text="{Binding MonthSalesAmount, StringFormat={}{0:N0}}" Style="{StaticResource Value}" />
                            <TextBlock Style="{StaticResource CaptionText}" Margin="0,4,0,0"
                                       Text="{Binding MonthSalesLength, StringFormat={}{0:N0} m}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Margin="6" MinWidth="220">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Dashboard.TodayPayments}" Style="{StaticResource CaptionText}" />
                            <TextBlock Text="{Binding TodayPaymentsAmount, StringFormat={}{0:N0}}" Style="{StaticResource Value}" />
                            <TextBlock Style="{StaticResource CaptionText}" Margin="0,4,0,0">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0}: {1}">
                                        <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="[Common.Quantity]" />
                                        <Binding Path="TodayPaymentsCount" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Border Style="{StaticResource CardBorder}" Margin="6">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="{loc:Loc Dashboard.CurrencyAndMarketPrices}" Style="{StaticResource SubtitleText}" />
                            <TextBlock HorizontalAlignment="Right"
                                       VerticalAlignment="Center" Style="{StaticResource CaptionText}">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} {1}">
                                        <Binding Source="{x:Static loc:TranslationSource.Instance}" Path="[Dashboard.Cbu]" />
                                        <Binding Path="RateDate" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                        <Border Margin="0,0,0,12" Padding="12,8"
                                Background="{DynamicResource WarningSubtle}"
                                CornerRadius="{DynamicResource RadiusMd}"
                                Visibility="{Binding MarketLoadFailed, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Width="14" Height="14" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource Warning}" Icon="TriangleExclamation" />
                                <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource Warning}" Text="{loc:Loc Dashboard.MarketLoadFailed}" />
                            </StackPanel>
                        </Border>
                        <WrapPanel>
                            <Border Style="{StaticResource MiniStat}">
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc Dashboard.UsdSum}" Style="{StaticResource CaptionText}" />
                                    <TextBlock Text="{Binding UsdRate, StringFormat={}{0:N2}}" Style="{StaticResource TitleText}" Margin="0,4,0,0" />
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <fa:IconImage Width="11" Height="11" VerticalAlignment="Center" Icon="ArrowUp"
                                                      Foreground="{DynamicResource Success}"
                                                      Visibility="{Binding UsdUp, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <fa:IconImage Width="11" Height="11" VerticalAlignment="Center" Icon="ArrowDown"
                                                      Foreground="{DynamicResource Danger}"
                                                      Visibility="{Binding UsdUp, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                        <TextBlock Text="{Binding UsdDiff, StringFormat={}{0:+#,##0.00;-#,##0.00;0}}"
                                                   Margin="4,0,0,0" VerticalAlignment="Center" FontSize="{DynamicResource FontSizeCaption}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Setter Property="Foreground" Value="{DynamicResource Danger}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UsdUp}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource Success}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MiniStat}">
                                <StackPanel>
                                    <TextBlock Text="{loc:Loc Dashboard.EurSum}" Style="{StaticResource CaptionText}" />
                                    <TextBlock Text="{Binding EurRate, StringFormat={}{0:N2}}" Style="{StaticResource TitleText}" Margin="0,4,0,0" />
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <fa:IconImage Width="11" Height="11" VerticalAlignment="Center" Icon="ArrowUp"
                                                      Foreground="{DynamicResource Success}"
                                                      Visibility="{Binding EurUp, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <fa:IconImage Width="11" Height="11" VerticalAlignment="Center" Icon="ArrowDown"
                                                      Foreground="{DynamicResource Danger}"
                                                      Visibility="{Binding EurUp, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                        <TextBlock Text="{Binding EurDiff, StringFormat={}{0:+#,##0.00;-#,##0.00;0}}"
                                                   Margin="4,0,0,0" VerticalAlignment="Center" FontSize="{DynamicResource FontSizeCaption}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                    <Setter Property="Foreground" Value="{DynamicResource Danger}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EurUp}" Value="True">
                                                            <Setter Property="Foreground" Value="{DynamicResource Success}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <ItemsControl ItemsSource="{Binding Metals}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource MiniStat}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource CaptionText}" />
                                                <TextBlock Text="{Binding Price}" Style="{StaticResource TitleText}" Margin="0,4,0,0" />
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <fa:IconImage Width="11" Height="11" VerticalAlignment="Center" Icon="ArrowUp"
                                                                  Foreground="{DynamicResource Success}"
                                                                  Visibility="{Binding IsUp, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                    <fa:IconImage Width="11" Height="11" VerticalAlignment="Center" Icon="ArrowDown"
                                                                  Foreground="{DynamicResource Danger}"
                                                                  Visibility="{Binding IsUp, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                                    <TextBlock Text="{Binding ChangePercent}" Margin="4,0,0,0"
                                                               VerticalAlignment="Center" FontSize="{DynamicResource FontSizeCaption}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                                <Setter Property="Foreground" Value="{DynamicResource Danger}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUp}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource Success}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </WrapPanel>
                        <TextBlock Text="{loc:Loc Dashboard.DataSource}"
                                   Foreground="{DynamicResource TextTertiary}" FontSize="{DynamicResource FontSizeCaption}" Margin="4,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="6">
                    <StackPanel>
                        <TextBlock Text="{Binding TrendTitle}" Style="{StaticResource SubtitleText}" Margin="0,0,0,12" />
                        <charts:LineChart Data="{Binding Chart}" Height="240" />
                    </StackPanel>
                </Border>

                <Grid Margin="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,6,0">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Dashboard.Top5Customers}" Style="{StaticResource SubtitleText}" Margin="0,0,0,12" />
                            <ItemsControl ItemsSource="{Binding TopCustomers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,6">
                                            <TextBlock Text="{Binding Customer}" Foreground="{DynamicResource TextPrimary}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,0,110,0" />
                                            <TextBlock Text="{Binding Amount, StringFormat={}{0:N0}}"
                                                       FontWeight="Bold" Foreground="{DynamicResource Success}" HorizontalAlignment="Right" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="6,0,0,0">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Dashboard.Top5Products}" Style="{StaticResource SubtitleText}" Margin="0,0,0,12" />
                            <ItemsControl ItemsSource="{Binding TopSellingProducts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,6">
                                            <TextBlock Text="{Binding Product}" Foreground="{DynamicResource TextPrimary}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,0,110,0" />
                                            <TextBlock Text="{Binding TotalLength, StringFormat={}{0:N0} m}"
                                                       FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Right" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <uc:BusyOverlay IsBusy="{Binding IsLoading}" Message="{loc:Loc Common.Loading}" />
    </Grid>
</Page>
